DB_PORT=5432
DB_NAME=citas_terapeuticas
DB_USER=postgres
DB_PASS=your_db_password

# PDF & Comprobantes
COMPROBANTE_BASE_URL=https://tu-dominio.com/comprobantes
COMPROBANTE_DIR=./storage/comprobantes

# Scheduler (notificaciones automáticas)
# Hora (24h) a la que el cron revisará citas del día siguiente
REMINDER_CRON_HOUR=09
REMINDER_CRON_MINUTE=00

# Seguridad
JWT_SECRET=your_super_secret_key
OTP_EXPIRY_MINUTES=5
